---
import LandingLayout from '../layouts/LandingLayout.astro';
import SiteHeader from '../components/landing/SiteHeader.astro';
import Hero from '../components/landing/Hero.astro';
import WhyTales from '../components/landing/WhyTales.astro';
import Features from '../components/landing/Features.astro';
import QuickStart from '../components/landing/QuickStart.astro';
import UseCases from '../components/landing/UseCases.astro';
import Determinism from '../components/landing/Determinism.astro';
import InstallCTA from '../components/landing/InstallCTA.astro';
import SiteFooter from '../components/landing/SiteFooter.astro';
import strings from '../i18n/en';
---

<LandingLayout title={strings.meta.title} description={strings.meta.description}>
	<SiteHeader />
	<main>
		<Hero />
		<WhyTales />
		<Features />
		<QuickStart />
		<UseCases />
		<Determinism />
		<InstallCTA />
	</main>
	<SiteFooter />
</LandingLayout>

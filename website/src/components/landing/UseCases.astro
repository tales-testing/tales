---
import strings from '../../i18n/en';
import { Code } from 'astro:components';

const u = strings.useCases;
---

<section class="border-t border-[var(--color-border)] bg-[var(--color-surface-2)]">
	<div class="mx-auto max-w-6xl px-6 py-20 lg:py-24">
		<div class="mx-auto max-w-2xl text-center">
			<h2 class="text-3xl font-bold tracking-tight md:text-4xl">{u.title}</h2>
			<p class="mt-4 text-lg text-[var(--color-text-muted)]">{u.subtitle}</p>
		</div>

		<div class="mt-14 grid gap-6 lg:grid-cols-3">
			{u.items.map((item) => (
				<div class="flex flex-col rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
					<span class="inline-block w-fit rounded-md bg-[var(--color-accent)]/15 px-2.5 py-0.5 text-xs font-semibold tracking-wide text-[var(--color-accent-hover)] uppercase">
						{item.tag}
					</span>
					<h3 class="mt-3 text-xl font-semibold text-[var(--color-text)]">{item.title}</h3>
					<p class="mt-2 text-[var(--color-text-muted)] leading-relaxed">{item.body}</p>
					<div class="mt-5 overflow-hidden rounded-lg border border-[var(--color-border)] text-[12px]">
						<Code code={item.snippet} lang="hcl" theme="github-dark-default" />
					</div>
				</div>
			))}
		</div>
	</div>
</section>

---
import strings from '../../i18n/en';
import logoDark from '../../assets/logo-dark.svg';
import { Image } from 'astro:assets';

const base = import.meta.env.BASE_URL;
---

<header
	class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[color-mix(in_oklab,var(--color-bg)_85%,transparent)] backdrop-blur"
>
	<div
		class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6"
	>
		<a href={base} class="flex items-center gap-2 text-[var(--color-text)] hover:opacity-80" aria-label="Tales home">
			<Image src={logoDark} alt="Tales" height={28} width={123} />
		</a>

		<nav class="flex items-center gap-1 text-sm">
			<a
				href={`${base}docs/getting-started/introduction/`}
				class="rounded-md px-3 py-2 text-[var(--color-text-muted)] hover:bg-[var(--color-surface)] hover:text-[var(--color-text)]"
			>
				{strings.nav.docs}
			</a>
			<a
				href="https://github.com/tales-testing/tales"
				class="rounded-md px-3 py-2 text-[var(--color-text-muted)] hover:bg-[var(--color-surface)] hover:text-[var(--color-text)]"
				aria-label="GitHub repository"
			>
				<svg viewBox="0 0 24 24" class="inline h-4 w-4 fill-current" aria-hidden="true">
					<path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.7.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.2 1.2.9-.3 1.9-.4 2.9-.4s2 .1 2.9.4c2.2-1.5 3.2-1.2 3.2-1.2.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z" />
				</svg>
			</a>
			<a
				href={`${base}docs/getting-started/introduction/`}
				class="ml-2 rounded-md bg-[var(--color-accent)] px-4 py-2 font-semibold text-white shadow-sm shadow-[var(--color-accent)]/30 transition hover:bg-[var(--color-accent-hover)]"
			>
				{strings.nav.getStarted}
			</a>
		</nav>
	</div>
</header>

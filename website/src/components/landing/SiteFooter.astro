---
import strings from '../../i18n/en';

const f = strings.footer;
const base = import.meta.env.BASE_URL;
const stripLeadingSlash = (path: string) => path.replace(/^\//, '');
const resolve = (href: string) =>
	href.startsWith('http') ? href : `${base}${stripLeadingSlash(href)}`;
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-bg)]">
	<div class="mx-auto max-w-6xl px-6 py-14">
		<div class="grid gap-10 md:grid-cols-3">
			<div>
				<p class="font-mono text-sm font-semibold tracking-tight text-[var(--color-text)]">
					<span class="text-[var(--color-accent)]">▸</span> Tales
				</p>
				<p class="mt-3 max-w-sm text-sm text-[var(--color-text-muted)] leading-relaxed">
					{f.tagline}
				</p>
			</div>

			{f.columns.map((col) => (
				<div>
					<h4 class="text-sm font-semibold text-[var(--color-text)]">{col.title}</h4>
					<ul class="mt-3 space-y-2 text-sm">
						{col.links.map((link) => (
							<li>
								<a
									href={resolve(link.href)}
									class="text-[var(--color-text-muted)] transition hover:text-[var(--color-text)]"
								>
									{link.label}
								</a>
							</li>
						))}
					</ul>
				</div>
			))}
		</div>

		<div class="mt-10 flex flex-col items-start justify-between gap-4 border-t border-[var(--color-border)] pt-6 text-xs text-[var(--color-text-faint)] md:flex-row md:items-center">
			<span>© {year} Tales contributors. MIT licensed.</span>
			<span>{f.colophon}</span>
		</div>
	</div>
</footer>

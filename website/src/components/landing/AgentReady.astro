---
import strings from '../../i18n/en';
import { Code } from 'astro:components';

const a = strings.agents;
---

<section id="ai-agents" class="border-t border-[var(--color-border)] bg-[var(--color-surface-2)]">
	<div class="mx-auto max-w-6xl px-6 py-20 lg:py-24">
		<div class="mx-auto max-w-2xl text-center">
			<p class="mb-5 inline-flex items-center gap-2 rounded-full border border-[var(--color-accent)]/30 bg-[var(--color-accent)]/10 px-3 py-1 text-xs font-semibold tracking-wide text-[var(--color-accent-hover)] uppercase">
				<svg viewBox="0 0 24 24" class="h-3.5 w-3.5 fill-current" aria-hidden="true">
					<path d="M12 2l1.6 4.6L18 8.2l-4.4 1.6L12 14l-1.6-4.2L6 8.2l4.4-1.6z" />
				</svg>
				{a.eyebrow}
			</p>
			<h2 class="text-3xl font-bold tracking-tight md:text-4xl">{a.title}</h2>
			<p class="mt-4 text-lg text-[var(--color-text-muted)]">{a.body}</p>
		</div>

		<div class="mt-14 grid items-start gap-12 lg:grid-cols-2">
			<div>
				<ul class="space-y-6">
					{a.bullets.map((b) => (
						<li class="flex items-start gap-4">
							<span class="mt-0.5 inline-flex h-9 w-9 flex-none items-center justify-center rounded-lg bg-[var(--color-accent)]/15 text-[var(--color-accent-hover)]">
								<svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<polyline points="20 6 9 17 4 12" />
								</svg>
							</span>
							<div>
								<h3 class="font-semibold text-[var(--color-text)]">{b.title}</h3>
								<p class="mt-1 text-[var(--color-text-muted)] leading-relaxed">{b.body}</p>
							</div>
						</li>
					))}
				</ul>

				<div class="mt-8 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-4">
					<div class="text-xs font-semibold tracking-wide text-[var(--color-text-muted)] uppercase">{a.install.label}</div>
					<div class="mt-2">
						<Code code={a.install.code} lang="bash" theme="github-dark-default" />
					</div>
					<p class="mt-2 text-sm text-[var(--color-text-faint)]">{a.install.note}</p>
				</div>
			</div>

			<div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-code-bg)] p-5 shadow-xl shadow-[var(--color-accent)]/10">
				<div class="flex items-center gap-2 text-sm font-medium text-[var(--color-text-muted)]">
					<svg viewBox="0 0 24 24" class="h-4 w-4 flex-none text-[var(--color-accent-hover)] fill-current" aria-hidden="true">
						<path d="M12 2l1.6 4.6L18 8.2l-4.4 1.6L12 14l-1.6-4.2L6 8.2l4.4-1.6z" />
					</svg>
					<span class="font-mono text-[var(--color-text)]">{a.card.skill}</span>
				</div>

				<div class="mt-4 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2 text-sm text-[var(--color-text)]">
					<span class="text-[var(--color-text-faint)]">you ›</span> {a.card.prompt}
				</div>

				<div class="mt-4 text-xs text-[var(--color-text-faint)]">{a.card.generated}</div>
				<div class="mt-2 overflow-hidden rounded-lg border border-[var(--color-border)] text-[12px]">
					<Code code={a.card.snippet} lang="hcl" theme="github-dark-default" />
				</div>
			</div>
		</div>
	</div>
</section>

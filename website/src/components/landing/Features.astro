---
import strings from '../../i18n/en';

const f = strings.features;

const icons = [
	// Single binary, package
	'M3 7l9-4 9 4-9 4-9-4zm0 5l9 4 9-4M3 17l9 4 9-4',
	// HCL2, document
	'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6M9 13h6M9 17h6',
	// Faker, sparkles
	'M12 3l1.5 4.5L18 9l-4.5 1.5L12 15l-1.5-4.5L6 9l4.5-1.5zM19 13l.8 2.5L22 16l-2.2.5L19 19l-.8-2.5L16 16l2.2-.5z',
	// Seed, replay
	'M3 12a9 9 0 0 1 15-6.7L21 8M21 3v5h-5M21 12a9 9 0 0 1-15 6.7L3 16M3 21v-5h5',
	// Providers, layers
	'M12 2 2 7l10 5 10-5zM2 17l10 5 10-5M2 12l10 5 10-5',
	// Parallel, bars
	'M4 4v16M10 8v12M16 4v16M22 10v10',
	// HTML report, chart
	'M3 3v18h18M7 14l4-4 4 4 5-5',
	// CI, server
	'M4 4h16v6H4zM4 14h16v6H4zM7 7h.01M7 17h.01',
];
---

<section class="border-t border-[var(--color-border)] bg-[var(--color-surface-2)]">
	<div class="mx-auto max-w-6xl px-6 py-20 lg:py-24">
		<div class="mx-auto max-w-2xl text-center">
			<h2 class="text-3xl font-bold tracking-tight md:text-4xl">{f.title}</h2>
			<p class="mt-4 text-lg text-[var(--color-text-muted)]">{f.subtitle}</p>
		</div>

		<div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
			{f.items.map((item, i) => (
				<div class="group rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 transition hover:border-[var(--color-accent)]/50">
					<svg viewBox="0 0 24 24" class="h-6 w-6 text-[var(--color-accent-hover)]" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d={icons[i]} />
					</svg>
					<h3 class="mt-4 text-base font-semibold text-[var(--color-text)]">{item.title}</h3>
					<p class="mt-2 text-sm text-[var(--color-text-muted)] leading-relaxed">{item.body}</p>
				</div>
			))}
		</div>
	</div>
</section>
